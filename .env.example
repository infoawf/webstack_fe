# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Inbox that receives contact form submissions
CONTACT_TO_EMAIL=hello@webstack.com

# Verified sender in Resend (use onboarding@resend.dev for dev/testing)
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Canonical site URL for sitemap, robots.txt, and SEO metadata
NEXT_PUBLIC_SITE_URL=https://webstack.live
